generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  flowsCreated FlowEvent[] @relation("UserFlowEvents")
}

enum Role {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

model Site {
  id        String     @id @default(uuid())
  name      String
  locations Location[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Location {
  id          String   @id @default(uuid())
  name        String
  description String?
  zone        String?
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  
  inventories Inventory[]
  sourceFlows Flow[]   @relation("SourceLocation")
  destFlows   Flow[]   @relation("DestLocation")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String     @id @default(uuid())
  name      String
  materials Material[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Material {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  description String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  inventories Inventory[]
  flows       Flow[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inventory {
  id          String   @id @default(uuid())
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  quantity    Float    @default(0)
  batchNumber String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([materialId, locationId, batchNumber]) // Unicité par matière, lieu et lot
}

model Flow {
  id               String   @id @default(uuid())
  materialId       String
  material         Material @relation(fields: [materialId], references: [id])
  sourceLocationId String
  sourceLocation   Location @relation("SourceLocation", fields: [sourceLocationId], references: [id])
  destLocationId   String
  destLocation     Location @relation("DestLocation", fields: [destLocationId], references: [id])
  quantity         Float
  status           FlowStatus @default(PENDING)
  
  events           FlowEvent[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum FlowStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
  ERROR
}

model FlowEvent {
  id        String   @id @default(uuid())
  flowId    String
  flow      Flow     @relation(fields: [flowId], references: [id])
  status    FlowStatus
  userId    String
  user      User     @relation("UserFlowEvents", fields: [userId], references: [id])
  notes     String?
  timestamp DateTime @default(now())
}
